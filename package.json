{
  "name": "ideas-tinder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "eslint . --ignore-pattern generated/** --ignore-pattern next-env.d.ts && tsc --noEmit",
    "prisma:compose:sqlite": "node scripts/compose-prisma-schema.mjs sqlite prisma/schema.prisma",
    "prisma:compose:postgres": "node scripts/compose-prisma-schema.mjs postgres prisma/schema.postgres.prisma",
    "db:push:postgres": "npm run prisma:compose:postgres && prisma db push --schema prisma/schema.postgres.prisma",
    "db:migrate:postgres": "npm run prisma:compose:postgres && prisma migrate deploy --schema prisma/schema.postgres.prisma",
    "db:generate": "npm run prisma:compose:sqlite && prisma migrate dev",
    "db:migrate": "npm run prisma:compose:sqlite && prisma migrate deploy",
    "db:push": "npm run prisma:compose:sqlite && prisma db push",
    "db:studio": "prisma studio",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "eslint . --ignore-pattern generated/** --ignore-pattern next-env.d.ts",
    "lint:fix": "eslint . --fix --ignore-pattern generated/** --ignore-pattern next-env.d.ts",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@prisma/client": "^6.6.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.3",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "superjson": "^2.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.6.0",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "npm@10.9.2"
}
