// This file is generated by scripts/compose-prisma-schema.mjs
// Engine: sqlite

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SwipeAction {
  DISLIKE
  LIKE_AND_FAVE
  FAVE_ONLY
}

model Post {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@index([name])
}

model User {
  id                  String                @id
  name                String //@db.Text
  email               String
  emailVerified       Boolean               @default(false)
  image               String? //@db.Text
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @default(now()) @updatedAt
  onboardingCompleted Boolean               @default(false)
  preferenceVector    Json?
  sessions            Session[]
  accounts            Account[]
  posts               Post[]
  fieldSelections     UserFieldSelection[]
  stacks              IdeaStack[]
  swipeEvents         SwipeEvent[]
  favorites           Favorite[]
  preferenceLogs      PreferenceUpdateLog[]

  @@unique([email])
  @@map("user")
}

model FieldCatalog {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  isCustom  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userSelections UserFieldSelection[]
  ideas          Idea[]
}

model UserFieldSelection {
  id        String   @id @default(cuid())
  userId    String
  fieldId   String
  createdAt DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  field FieldCatalog @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([userId, fieldId])
  @@index([userId])
  @@index([fieldId])
}

model Idea {
  id          String   @id @default(cuid())
  title       String
  description String
  vector      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  fieldId     String?

  field       FieldCatalog?        @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  chunks      IdeaChunkEmbedding[]
  stackItems  IdeaStackItem[]
  swipeEvents SwipeEvent[]
  favorites   Favorite[]

  @@index([fieldId])
}

model IdeaChunkEmbedding {
  id         String   @id @default(cuid())
  ideaId     String
  chunkIndex Int
  content    String
  vector     Json
  createdAt  DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ideaId, chunkIndex])
  @@index([ideaId])
}

model IdeaStack {
  id          String   @id @default(cuid())
  userId      String
  createdAt   DateTime @default(now())
  refreshedAt DateTime @default(now()) @updatedAt
  expiresAt   DateTime

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       IdeaStackItem[]
  swipeEvents SwipeEvent[]

  @@index([userId])
  @@index([expiresAt])
}

model IdeaStackItem {
  id       String @id @default(cuid())
  stackId  String
  ideaId   String
  position Int

  stack IdeaStack @relation(fields: [stackId], references: [id], onDelete: Cascade)
  idea  Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([stackId, position])
  @@index([ideaId])
}

model SwipeEvent {
  id         String      @id @default(cuid())
  userId     String
  ideaId     String
  stackId    String?
  action     SwipeAction
  scoreDelta Float
  createdAt  DateTime    @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea  Idea       @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  stack IdeaStack? @relation(fields: [stackId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([ideaId])
  @@index([stackId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  ideaId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId])
  @@index([userId, createdAt])
}

model PreferenceUpdateLog {
  id             String   @id @default(cuid())
  userId         String
  reason         String
  previousVector Json?
  updatedVector  Json
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String? //@db.Text
  userAgent String? //@db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String //@db.Text
  providerId            String //@db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String? //@db.Text
  refreshToken          String? //@db.Text
  idToken               String? //@db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String? //@db.Text
  password              String? //@db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String //@db.Text
  value      String //@db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}
